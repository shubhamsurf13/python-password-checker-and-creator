# в”Җв”Җв”Җ ANALYSIS в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
def check_charset(pwd):
    return (bool(re.search(r'[a-z]', pwd)),
            bool(re.search(r'[A-Z]', pwd)),
            bool(re.search(r'\d', pwd)),
            bool(re.search(r'[!@#$%^&*()\-_=+\[\]{};:\'",.<>/?\\|`~]', pwd)))

def entropy(pwd):
    pool = 0
    h, u, d, s = check_charset(pwd)
    if h: pool += 26
    if u: pool += 26
    if d: pool += 10
    if s: pool += 32
    if pool == 0: pool = 1
    return len(pwd) * math.log2(pool), pool

def crack_time_estimate(entropy_bits):
    seconds = (2 ** entropy_bits) / 1e10
    if seconds < 1:           return f"{BG_R} INSTANT {X}", R
    elif seconds < 60:        return f"{R}{seconds:.1f} seconds{X}", R
    elif seconds < 3600:      return f"{R}{seconds/60:.1f} minutes{X}", R
    elif seconds < 86400:     return f"{Y}{seconds/3600:.1f} hours{X}", Y
    elif seconds < 31536000:  return f"{Y}{seconds/86400:.1f} days{X}", Y
    elif seconds < 3.154e9:   return f"{G}{seconds/31536000:.1f} years{X}", G
    else:                     return f"{G}{seconds/3.154e9:.2e} centuries{X}", G

def detect_patterns(pwd):
    patterns = []
    if re.search(r'(.)\1{2,}', pwd):
        patterns.append((R, "Repeated characters detected (aaa, 111...)"))
    if re.search(r'(012|123|234|345|456|567|678|789|abc|bcd|cde)', pwd.lower()):
        patterns.append((R, "Sequential pattern detected (abc, 123...)"))
    if re.search(r'(qwerty|asdf|zxcv|qazwsx|1qaz)', pwd.lower()):
        patterns.append((R, "Keyboard walk detected (qwerty, asdf...)"))
    if re.search(r'(password|pass|admin|login|user|root)', pwd.lower()):
        patterns.append((R, "Common word embedded in password"))
    if re.search(r'(19|20)\d{2}', pwd):
        patterns.append((Y, "Year pattern detected (1998, 2023...)"))
    if not patterns:
        patterns.append((G, "No common patterns found вҖ” clean!"))
    return patterns

def score_password(pwd):
    score  = 0
    issues = []
    tips   = []
    h, u, d, s = check_charset(pwd)
    ent, pool  = entropy(pwd)

    if len(pwd) >= 16:   score += 30
    elif len(pwd) >= 12: score += 20
    elif len(pwd) >= 8:  score += 10; tips.append("Use 12+ characters")
    else:                issues.append("Too short (< 8 chars)"); tips.append("Minimum 12-16 chars recommended")

    if h: score += 10
    else: tips.append("Add lowercase letters (a-z)")
    if u: score += 10
    else: tips.append("Add uppercase letters (A-Z)")
    if d: score += 10
    else: tips.append("Add numbers (0-9)")
    if s: score += 15
    else: tips.append("Add symbols (!@#$%^&*...)")

    if ent >= 60:   score += 25
    elif ent >= 40: score += 15
    elif ent >= 28: score += 5

    if pwd.lower() in COMMON_PASSWORDS:
        score = max(0, score - 50)
        issues.append("PASSWORD FOUND IN BREACH DATABASE")
    if re.search(r'(.)\1{2,}', pwd):   score = max(0, score - 10)
    if re.search(r'(qwerty|asdf|1234|abcd)', pwd.lower()): score = max(0, score - 10)

    score = min(score, 100)

    if score >= 80:   label, color = "FORTRESS  в–Ҳв–Ҳ VERY STRONG", G
    elif score >= 60: label, color = "GUARDED   в–“в–“ STRONG",      Y
    elif score >= 40: label, color = "EXPOSED   в–’в–’ MODERATE",    Y
    elif score >= 20: label, color = "CRACKABLE в–‘в–‘ WEAK",        R
    else:             label, color = "BREACHED  в–Әв–Ә CRITICAL",    R

    return score, label, color, ent, pool, issues, tips

def draw_score_bar(score, color):
    filled = int(score / 5)
    empty  = 20 - filled
    return f"  [{color}{'в–Ҳ' * filled}{DIM}{'в–‘' * empty}{X}] {color}{score}/100{X}"

